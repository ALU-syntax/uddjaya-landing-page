<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Registrasi membership UD DJAYA berhasil">
    <meta name="keywords" content="UD DJAYA, Membership, Registrasi Berhasil">
    <meta name="author" content="UD DJAYA">
    <meta name="theme-color" content="#c83d3b">
    <meta property="og:title" content="Registrasi Membership UD DJAYA Berhasil">
    <meta property="og:description" content="Terima kasih telah mendaftar membership UD DJAYA.">
    <meta property="og:url" content="https://www.uddjaya.com">
    <meta property="og:type" content="website">

    <link rel="icon" href="/img/logo.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/vendor/normalize.min.css">
    <link rel="stylesheet" href="/css/index.css">

    <title><%= title %> | UD DJAYA</title>
</head>

<body class="finish-page">
    <div id="particles-js" aria-hidden="true"></div>
    <div id="magic" data-text="BERHASIL" aria-hidden="true"></div>

    <main class="playground">
        <div class="finish-message" aria-labelledby="finish-title">
            <!-- <h1 id="finish-title">Registrasi Berhasil</h1> -->
            <p style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">Terima kasih sudah mendaftar membership UD DJAYA. Silakan cek email kamu untuk informasi registrasi.</p>
        </div>

        <div class="bottom-position">
            <img class="brand-logo" src="/img/logo-cream.png" alt="UD DJAYA">
            <p class="tagline">#HariHariBerdjaya</p>
        </div>
    </main>

    <aside class="instagram-follow" aria-label="Instagram UD DJAYA">
        <a href="https://www.instagram.com/ud.djaya/" target="_blank" rel="noopener noreferrer">
            <img src="/img/instagram_icon.png" alt="" aria-hidden="true">
            <span>
                <strong>Follow Instagram</strong>
                <small>@ud.djaya</small>
            </span>
        </a>
    </aside>

    <script src="/js/vendor/particles.min.js" defer></script>
    <script src="/js/index.js" type="module"></script>
</body>

</html>
